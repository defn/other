# =============================================================================
# Bazel
# =============================================================================

/bazel-*
MODULE.bazel.lock
.bazelrc.user
# Per-clone path config written by m/bin/bootstrap-bazelrc
.bazelrc.workspace

# =============================================================================
# Generated / cached files
# =============================================================================

# Catalog cache (generated by mise run gen, consumed by generators)
.catalog-cache.json

# Coordinator dispatch run artifacts (AIDR-00132 / AIDR-00133).
# Snapshots, per-brick result CUE, and the running plan are
# transient; defn dispatch writes them under .defn/dispatch/<run-id>.
/.defn/

# Bootstrap target repos nested under m/ for portability testing
# (AIDR-00138). m/ should not track its own bootstrap targets.
/other/

# =============================================================================
# clj-kondo
# =============================================================================

.clj-kondo/

# =============================================================================
# OpenTofu
# =============================================================================

.terraform/
.plan
.plan.txt

# =============================================================================
# Registry TLS CA private key (used to re-sign the leaf cert during
# `mise run gen-registry-cert`; not needed at runtime). Tracking the
# leaf is fine for a dev-only registry; tracking the CA private key
# would let any cloned dev workstation mint trusted leaves, which we
# don't want.
# =============================================================================
kernel/gross/registry-ca-key.pem

# =============================================================================
# Override home .gitignore (these are source code here, not build artifacts)
# =============================================================================

!build/
!env/
!go/
# Spec lattice (uncompressed not tracked; .gz tracked via git-lfs)
var/lattice.json
