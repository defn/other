# Leaf 'spiral' hardcodes leaf 'defn's profile value 'defn-org' in
# main.tf: AIDR-00102 violation.

! exec crosstenantlit input.json
stdout 'tenant/spiral/k3d/x/main\.tf:1 contains forbidden literal "defn-org"'
stdout 'owned by tenant "defn"'
stdout 'kind=profile'
stdout 'Discovered leaf tenants: defn, spiral\.'

-- input.json --
{
  "tenants": [
    {"name": "defn", "path": "tenant/defn", "is_leaf": true, "profiles": ["defn-org"]},
    {"name": "spiral", "path": "tenant/spiral", "is_leaf": true, "profiles": ["spiral-org"]}
  ],
  "files": [
    {"path": "tenant/spiral/k3d/x/main.tf", "tenant": "spiral", "content": "profile = \"defn-org\"\n"}
  ],
  "gen_writes": []
}
