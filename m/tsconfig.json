{
	"compilerOptions": {
		"target": "ES2020",
		"module": "nodenext",
		"lib": ["ES2020"],
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"moduleResolution": "nodenext",
		"resolveJsonModule": true
	},
	"exclude": ["node_modules", "dist", "bazel-*"]
}
