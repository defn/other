)

fmt_test(
    name = "generate_go_fmt",
    src = "generate.go",
    tool = "gofmt",
)

fmt_test(
    name = "mime_go_fmt",
    src = "mime.go",
    tool = "gofmt",
)

fmt_test(
    name = "mime_test_go_fmt",
    src = "mime_test.go",
    tool = "gofmt",
)

fmt_test(
    name = "deps_cue_fmt",
    src = "deps.cue",
    tool = "cue",
)

tagged_file(
    name = "build_bazel_tag",
    src = "BUILD.bazel",
    tags = [
        "bazel",
        "bazel-build",
    ],
)

tagged_file(
    name = "generate_go_tag",
    src = "generate.go",
    tags = [
        "go",
        "source",
    ],
)

tagged_file(
    name = "mime_go_tag",
    src = "mime.go",
    tags = [
        "go",
        "source",
    ],
)

tagged_file(
    name = "mime_test_go_tag",
    src = "mime_test.go",
    tags = [
        "go",
        "source",
    ],
)

tagged_file(
    name = "deps_cue_tag",
    src = "deps.cue",
    tags = [
        "cue",
        "source",
    ],
)

tagged_package(exclude = ["generate.go", "mime.go", "mime_test.go", "BUILD.bazel", "deps.cue"])
