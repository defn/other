load("//kernel:tagged.bzl", "tagged_file", "tagged_package")

go_library(
    name = "config",
    srcs = [
        "config.go",
        "schema.go",
    ],
    importpath = "github.com/defn/other/m/tenant/library/go/lib/config",
    visibility = ["//visibility:public"],
