        "@com_github_spf13_viper//:viper",
        "@org_cuelang_go//cue",
        "@org_cuelang_go//cue/cuecontext",
    ],
)

fmt_test(
    name = "build_bazel_fmt",
    src = "BUILD.bazel",
    tool = "buildifier",
)

fmt_test(
    name = "config_go_fmt",
    src = "config.go",
    tool = "gofmt",
)

fmt_test(
    name = "schema_go_fmt",
