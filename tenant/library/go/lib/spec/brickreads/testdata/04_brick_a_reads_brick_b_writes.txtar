# A reads a path that B writes. A is stale relative to B.

! exec brickreads input.json
stdout '^a stale on b: shared/x\.cue$'

-- input.json --
{
  "bricks": {
    "a": {"path": "foo"},
    "b": {"path": "bar"}
  },
  "brick_io": {
    "a": {"reads": ["shared/x.cue"], "writes": ["foo/out.cue"]},
    "b": {"reads": ["bar/in.cue"], "writes": ["shared/x.cue"]}
  }
}
