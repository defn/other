"""Go library 'stdin' -- generated by defn gen."""

load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")
load("//kernel:fmt.bzl", "fmt_test")
load("//kernel:tagged.bzl", "tagged_file", "tagged_package")

go_library(
    name = "stdin",
    srcs = ["stdin.go"],
    importpath = "github.com/defn/other/m/v/buildkite--agent/internal/stdin",
    visibility = ["//visibility:public"],
)

go_test(
    name = "stdin_test",
    srcs = ["main_test.go"],
    embed = [":stdin"],
)

fmt_test(
    name = "build_bazel_fmt",
    src = "BUILD.bazel",
    tool = "buildifier",
)

fmt_test(
    name = "stdin_go_fmt",
    src = "stdin.go",
    tool = "gofmt",
)

fmt_test(
    name = "main_test_go_fmt",
    src = "main_test.go",
    tool = "gofmt",
)

fmt_test(
    name = "deps_cue_fmt",
    src = "deps.cue",
    tool = "cue",
)

tagged_file(
    name = "build_bazel_tag",
    src = "BUILD.bazel",
    tags = [
        "bazel",
        "bazel-build",
    ],
)

tagged_file(
    name = "stdin_go_tag",
    src = "stdin.go",
    tags = [
        "go",
        "source",
    ],
)

tagged_file(
    name = "main_test_go_tag",
    src = "main_test.go",
    tags = [
        "go",
        "source",
    ],
)

tagged_file(
    name = "deps_cue_tag",
    src = "deps.cue",
    tags = [
        "cue",
        "source",
    ],
)

tagged_package(exclude = ["stdin.go", "main_test.go", "BUILD.bazel", "deps.cue"])
